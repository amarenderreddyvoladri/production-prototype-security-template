+
+	// ======================== 🔒 SECURITY FLAGS ========================
+
+	private boolean revoked = false;
+	private boolean expired = false;
+
+	/**
+	 * Detect reuse of refresh tokens (advanced security)
+	 */
+	private boolean refreshUsed = false;
+
+	// ======================== 📱 DEVICE INFO ========================
+
