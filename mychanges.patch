+
+	/**
+	 * Account manually disabled by admin
+	 */
+	@Column(nullable = false)
+	private boolean enabled = true;
+
+	/**
+	 * Lock mechanism (brute-force protection)
+	 */
+	@Column(nullable = false)
+	private boolean accountLocked = false;
+
+	/**
+	 * Number of failed login attempts
+	 */
+	@Column(nullable = false)
